# ============================================================================
# Core (required)
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# REQUIRED. Used in all member-facing emails (registration links, abstract
# revision links, team-invite links, waitlist notifications). Code throws on
# missing — a wrong-domain link to a real member is worse than a startup error.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# Tenant (multi-deployment of this repo)
# ============================================================================
# Required. Determines which org's events this deployment reads/writes.
# Values: "amasi" | "college". Same Supabase DB; the events.tenant column
# scopes per-deployment. Code throws on missing or invalid value.
NEXT_PUBLIC_TENANT=college
# Optional. Set to ".amasi.org" on a deployment that should share Supabase
# auth cookies with sibling *.amasi.org subdomains (e.g. membership portal).
# Leave UNSET for host-only cookies (default, what collegeofmas.org.in uses).
NEXT_PUBLIC_COOKIE_DOMAIN=

# ============================================================================
# Email
# ============================================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_WEBHOOK_SECRET=
BLASTABLE_API_KEY=
BLASTABLE_FROM_EMAIL=
EMAIL_FROM=
ADMIN_ALERT_EMAIL=

# ============================================================================
# Payments (Razorpay)
# ============================================================================
# Server-side credentials (never bundled into the browser).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook signing secret. The webhook URL is per-deployment:
#   College:  https://collegeofmas.org.in/api/payments/razorpay/webhook
#   AMASI:    https://events.amasi.org/api/payments/razorpay/webhook
# Each Razorpay merchant account is configured with its own webhook URL +
# secret in the Razorpay dashboard; Razorpay routes events to the correct
# deployment, which validates with this env value.
RAZORPAY_WEBHOOK_SECRET=
# Client-side key (same value as RAZORPAY_KEY_ID). NEXT_PUBLIC_ prefix is
# what bundles it into the browser JS so the Razorpay Checkout modal can
# initialize. Keep both vars even though they're the same value — the prefix
# is the contract that says "this is OK to expose to the client".
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# ============================================================================
# AI / OCR
# ============================================================================
ANTHROPIC_API_KEY=
OCR_SPACE_API_KEY=

# ============================================================================
# Security (recommended in production)
# ============================================================================
# Used for IP hashing in analytics. If unset, a fallback key is used and a
# warning is logged at runtime. Currently set in Production and Development;
# not set in Preview (preview deployments fall back to the runtime default,
# which is acceptable since preview deployments are internal and infrequent).
NEXTAUTH_SECRET=

# ============================================================================
# WhatsApp messaging
# ============================================================================
GALLABOX_API_KEY=
GALLABOX_API_SECRET=
GALLABOX_CHANNEL_ID=
GALLABOX_TEMPLATE_SPEAKER_INVITATION=
# Generic pre-approved template reused across all events for ad hoc Compose
# sends (Events > Communications > Compose > WhatsApp). Must exactly match
# the template name approved in the Gallabox dashboard; defaults to "basic"
# if unset. Its single body variable ({{1}}) carries the full message text.
GALLABOX_TEMPLATE_BASIC=
# HMAC SHA-256 secret shared with the Gallabox webhook registered at
# /api/webhooks/gallabox — required for delivery/read/failed status updates.
GALLABOX_WEBHOOK_SECRET=
QIKCHAT_API_KEY=
QIKCHAT_WHATSAPP_ID=

# ============================================================================
# Third-party integrations
# ============================================================================
AIRTABLE_PAT=
AIRTABLE_CONVOCATION_BASE=
AIRTABLE_CONVOCATION_TABLE=
LINKILA_API_KEY=
AIRLABS_API_KEY=
AVIATIONSTACK_API_KEY=
NEXT_PUBLIC_AIRLABS_API_KEY=
FILLOUT_API_KEY=
BOOSTSPACE_WEBHOOK_URL=
WEBHOOK_URLS=

# ============================================================================
# Cron / infrastructure
# ============================================================================
CRON_SECRET=

# ============================================================================
# Branding (optional — defaults applied if unset)
# ============================================================================
NEXT_PUBLIC_COMPANY_NAME=
NEXT_PUBLIC_COMPANY_FULL_NAME=
NEXT_PUBLIC_COMPANY_WEBSITE=
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_DEFAULT_COUNTRY=
NEXT_PUBLIC_DEFAULT_CURRENCY=
NEXT_PUBLIC_DEFAULT_CURRENCY_SYMBOL=
NEXT_PUBLIC_DEFAULT_TIMEZONE=

# ============================================================================
# Optional URLs
# ============================================================================
NEXT_PUBLIC_LANDING_PAGE=
NEXT_PUBLIC_MEMBERSHIP_APPLICATION_URL=
NEXT_PUBLIC_MEMBERSHIP_LOOKUP_URL=
NEXT_PUBLIC_SKILL_COURSE_URL=
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_BASE_URL=

# ============================================================================
# Feature flags (set to 'true' to enable; modules hidden by default if unset)
# ============================================================================
NEXT_PUBLIC_ENABLE_ATTENDEES=
NEXT_PUBLIC_ENABLE_EXAMINATION=
NEXT_PUBLIC_ENABLE_FACULTY=
NEXT_PUBLIC_ENABLE_FORMS=
NEXT_PUBLIC_ENABLE_MEMBERSHIP=
NEXT_PUBLIC_ENABLE_MULTIPLE_EVENTS=
NEXT_PUBLIC_ENABLE_TEAM=
NEXT_PUBLIC_ENABLE_TRAVEL=
